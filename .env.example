# ============================================================
# WADEM — Environment Variables
# Copy this to .env.local and fill in your real values
# ============================================================

# ── Firebase Auth (REQUIRED for login) ──────────────────────
# 1. Go to https://console.firebase.google.com
# 2. Create a project (or use existing)
# 3. Enable Authentication → Phone and Google sign-in methods
# 4. Go to Project Settings → General → Your Apps → Web app
# 5. Copy the config values below
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Google Sheets Backend (REQUIRED for orders) ─────────────
# 1. Go to https://console.cloud.google.com
# 2. Enable "Google Sheets API"
# 3. Create a Service Account → download JSON key
# 4. Base64-encode the JSON: cat key.json | base64
# 5. Create a Google Sheet with 3 tabs: "Orders", "Customers", "Promotions"
# 6. Share the sheet with the service account email (Editor access)
# 7. Copy the Sheet ID from the URL (between /d/ and /edit)
#
# Orders tab headers:    OrderID | CustomerUID | CustomerName | RestaurantID | RestaurantName | Items | Subtotal | DeliveryFee | Discount | Total | Status | PromoCode | CreatedAt | DeliveryAddress
# Customers tab headers: UID | Name | Phone | Email | Address | SignupDate | TotalOrders | TotalSpent | ReferralCode | Preferences
# Promotions tab headers: Code | Type | Value | MinOrder | MaxUses | CurrentUses | StartDate | EndDate | Audience | Active
GOOGLE_SHEETS_CREDENTIALS=
GOOGLE_SHEET_ID=

# ── AI Assistant (OPTIONAL — falls back to rule-based) ──────
# Option A: OpenAI (primary) — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Option B: Groq (fallback) — https://console.groq.com/keys
GROQ_API_KEY=

# ── OpenWeather (OPTIONAL — for weather-based greetings) ─────
# 1. Go to https://openweathermap.org/api
# 2. Sign up and get a free API key
NEXT_PUBLIC_OPENWEATHER_API_KEY=

# ── Google Maps (REQUIRED for address picker) ────────────────
# 1. Go to https://console.cloud.google.com
# 2. Enable "Maps JavaScript API" and "Places API"
# 3. Create an API key (restrict to your domains for production)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ── Lezzoo Order Integration (REQUIRED for real orders) ────
# Base URL for the Wadem-Lezzoo hooks server
WADEM_HOOKS_HOST=https://lezzoo-wadem-hooks.lezzoodevs.com
WADEM_API_KEY=wdm_ak_7f3b9c2e4a1d8f5e6b0c3a9d7e2f1b4a

# ── OTPiq SMS Verification (OPTIONAL) ─────────────────────
OTPIQ_API_KEY=

# ── App Config ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://wadem.krd
NEXT_PUBLIC_APP_NAME=Wadem
